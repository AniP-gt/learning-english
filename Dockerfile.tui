FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /app/bin/tui ./cmd/tui

FROM alpine:latest
RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /app/bin/tui .

ENV LEARNING_DATA_DIR=/data
VOLUME /data

CMD ["./tui"]
